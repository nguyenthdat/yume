{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "general": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.2,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
          "requirements-coding-orchestrator": "allow",
          "senior-coding-engineer": "allow",
          "android-senior-engineer": "allow",
          "rust-senior-engineer": "allow",
          "mobile-ai-architecture-orchestrator": "allow",
          "rust-uniffi-android-architect": "allow",
          "mobile-ocr-architect": "allow",
          "llm-rag-chatbot-architect": "allow",
          "architecture-qa-reviewer": "allow",
        },
      },
    },
    "mobile-ai-architecture-orchestrator": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.2,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
          "rust-uniffi-android-architect": "allow",
          "android-senior-engineer": "allow",
          "rust-senior-engineer": "allow",
          "mobile-ocr-architect": "allow",
          "llm-rag-chatbot-architect": "allow",
          "architecture-qa-reviewer": "allow",
        },
      },
    },
    "requirements-coding-orchestrator": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.15,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
          "senior-coding-engineer": "allow",
          "android-senior-engineer": "allow",
          "rust-senior-engineer": "allow",
          "architecture-qa-reviewer": "allow",
        },
      },
    },
    "senior-coding-engineer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
    "android-senior-engineer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
    "rust-senior-engineer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
    "rust-uniffi-android-architect": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
    "mobile-ocr-architect": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
    "llm-rag-chatbot-architect": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
    "architecture-qa-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
    },
  },
  "formatter": true,
  "lsp": true,
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
  },
  "mcp": {
    "docs-rs": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "@nuskey8/docs-rs-mcp@latest", "-y"],
    },
    "rust-analyzer": {
      "enabled": true,
      "type": "local",
      "command": ["rust-analyzer-mcp"],
    },
    "cargo-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["cargo-mcp", "serve"],
    },
    "cratesio-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["cratesio-mcp"],
    },
    "mobile-device-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "@srmorete/mobile-device-mcp@latest"],
    },
    "jetbrains": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:64342/stream",
    },
  },
}
