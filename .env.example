# Yume environment configuration
# Copy to .env and fill in values for your environment
#
# Backend runs locally (cargo run). Connect to Docker services via localhost.
# If running backend in Docker, use service names (opencode, qdrant, postgres, keydb).

# Environment
YUME_ENV=development
YUME_RETENTION_DAYS=30
YUME_LOG_PROMPTS=true
YUME_LOG_PROMPTS_REDACT=true
YUME_PUBLIC_BASE_URL=http://localhost:3000
YUME_JWT_ISSUER=yume

# Secrets (never commit real values)
YUME_GOOGLE_ANDROID_CLIENT_ID=
DEEPSEEK_API_KEY=

# OpenCode Server
OPENCODE_BASE_URL=http://localhost:4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=yume_dev_pass

# Infrastructure (Docker services exposed on localhost)
QDRANT_URL=http://localhost:6334
DATABASE_URL=postgres://yume:yume_dev@localhost:5432/yume
KEYDB_URL=redis://localhost:6379
