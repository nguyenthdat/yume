# Yume environment configuration
# Copy to .env and fill in values

# Environment
YUME_ENV=development
YUME_RETENTION_DAYS=30
YUME_LOG_PROMPTS=true
YUME_LOG_PROMPTS_REDACT=true
YUME_PUBLIC_BASE_URL=http://localhost:3000
YUME_JWT_ISSUER=yume
YUME_GOOGLE_ANDROID_CLIENT_ID=

# =========================================================================
# LLM Providers (choose one via LLM_PROVIDER)
#   deepseek | openai | opencode | mock
# =========================================================================
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o-mini

# OpenAI OAuth (future — requires OAuth app registration)
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_CLIENT_SECRET=
# OPENAI_OAUTH_REFRESH_TOKEN=

# OpenCode Server (project-context)
OPENCODE_BASE_URL=http://localhost:4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=yume_dev_pass

# =========================================================================
# Infrastructure
# =========================================================================
QDRANT_URL=http://localhost:6334
DATABASE_URL=postgres://yume:yume_dev@localhost:5432/yume
KEYDB_URL=redis://localhost:6379
