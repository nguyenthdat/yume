namespace yume {
    // Functions
    [Throws=YumeError]
    string current_schema_version();

    [Throws=YumeError]
    string build_chat_request_json(string message_content, string conversation_id);
};

// ---------------------------------------------------------------------------
// Dictionaries (Rust struct → Kotlin data class)
// ---------------------------------------------------------------------------

dictionary ChatMessage {
    string role;
    string content;
};

dictionary TextDelta {
    string text;
};

dictionary ChatStarted {
    string conversation_id;
    string message_id;
};

dictionary MessageDelta {
    u64 seq;
    TextDelta delta;
};

// ---------------------------------------------------------------------------
// Error type
// ---------------------------------------------------------------------------

[Error]
enum YumeError {
    "InvalidInput",
    "SerializationError",
};
