          "*": "deny",
          "senior-coding-engineer": "allow",
          "android-senior-engineer": "allow",
          "rust-senior-engineer": "allow",
          "architecture-qa-reviewer": "allow"
        }
      }
    },
    "senior-coding-engineer": {
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "task": {
          "*": "deny"
        }
      }
    },
    "android-senior-engineer": {
